# Supabase Configuration
# Copy values dari Supabase Dashboard > Project Settings > API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Backend-only configuration (NEVER expose SERVICE_ROLE_KEY ke frontend)
# Generate these in Supabase Dashboard > Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Authentication (required for backend auth routes)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-min-32-chars-change-in-production

# Backend configuration
VITE_BACKEND_URL=http://localhost:3002
CORS_ORIGIN=http://localhost:5173
PORT=3002

# Database (MySQL legacy routes - disabled by default)
# Only needed if ENABLE_LEGACY_MYSQL_ROUTES=true
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=pos_raja_db
DB_CONNECTION_LIMIT=10

# WhatsApp integration via Fonnte (backend-only, do not prefix with VITE_)
FONNTE_TOKEN=YOUR_TOKEN_HERE
FONNTE_TARGETS=6287884820507,6285659085578
FONNTE_DRY_RUN=true

# Feature flags
ENABLE_LEGACY_MYSQL_ROUTES=false
INTEGRATION_RATE_LIMIT_MAX=10
INTEGRATION_RATE_LIMIT_WINDOW_MS=60000

# Runtime stabilization (frontend)
VITE_ALLOW_UNSTABLE_RUNTIME=false
VITE_DISABLE_REALTIME=true
VITE_DISABLE_PRESENCE=true
VITE_BACKGROUND_PRELOAD=false
VITE_MINIMAL_DATA_PROVIDER=true
VITE_DISABLE_REPORTS=false
