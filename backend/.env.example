# Backend configuration - copy to .env and fill all values
# ⚠️ NEVER commit actual .env file to git - only use .env.example as template

# Supabase (required)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Authentication (required for auth routes)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-min-32-chars

# Server
PORT=3002
CORS_ORIGIN=http://localhost:5173

# Database (MySQL legacy - only if ENABLE_LEGACY_MYSQL_ROUTES=true)
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=pos_raja_db
DB_CONNECTION_LIMIT=10

# WhatsApp notifications via Fonnte (backend-only)
FONNTE_TOKEN=YOUR_TOKEN_HERE
FONNTE_TARGETS=6287884820507,6285659085578
FONNTE_DRY_RUN=true

# Feature flags
ENABLE_LEGACY_MYSQL_ROUTES=false
INTEGRATION_RATE_LIMIT_MAX=10
INTEGRATION_RATE_LIMIT_WINDOW_MS=60000

# Node environment
NODE_ENV=development
